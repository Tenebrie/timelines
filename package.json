{
	"name": "timelines",
	"version": "0.0.0",
	"license": "GPL-3.0-or-later",
	"description": "",
	"private": true,
	"subPackages": [
		"app/styx-frontend",
		"app/rhea-backend",
		"app/calliope-websockets",
		"app/orpheus-mcp",
		"app/thetis-landing",
		"app/ts-shared",
		"library/tiptap-schema",
		"test/e2e",
		"test/load"
	],
	"scripts": {
		"postinstall": "NPM_CONFIG_PREFER_OFFLINE=true NPM_CONFIG_AUDIT=false NPM_CONFIG_FUND=false subpkg install && husky",
		"openapi": "./scripts/dev-openapi.sh",
		"migrate": "./scripts/dev-migrate.sh",
		"dev": "npm run docker:start",
		"docker": "npm run docker:start",
		"docker:start": ". ./scripts/prepare-local-dev.sh && docker compose -f docker-compose.common.yml -f docker-compose.dev.yml up --build",
		"docker:build": ". ./scripts/prepare-local-dev.sh && docker compose -f docker-compose.common.yml -f docker-compose.dev.yml build --no-cache",
		"docker:preview": "docker compose -f docker-compose.ci.yml up --build",
		"docker:down": ". ./scripts/prepare-local-dev.sh && docker compose -f docker-compose.common.yml -f docker-compose.dev.yml down",
		"docker:destroy": ". ./scripts/prepare-local-dev.sh && docker compose -f docker-compose.common.yml -f docker-compose.dev.yml down -v --rmi all --remove-orphans",
		"docker:update": "./scripts/dev-install.sh",
		"docker:fullinstall": "./scripts/dev-fullinstall.sh",
		"docker:prod:push": "./scripts/docker-prod-push.sh",
		"docker:stop": "docker stop $(docker ps -a -q)",
		"redis:clear": "docker exec -it timelines-redis-1 redis-cli FLUSHALL",
		"tsc": "(cd app/styx-frontend && npm run tsc) && (cd app/rhea-backend && npm run tsc) && (cd app/calliope-websockets && npm run tsc) && (cd app/orpheus-mcp && npm run tsc)",
		"lint": "(cd app/styx-frontend && npm run lint) && (cd app/rhea-backend && npm run lint) && (cd app/calliope-websockets && npm run lint) && (cd app/orpheus-mcp && npm run lint)",
		"test": "npm run test:styx && npm run test:rhea && npm run test:calliope && npm run test:orpheus && npm run test:e2e",
		"prisma": "cd app/rhea-backend && npx prisma",
		"test:styx": "cd app/styx-frontend && npm run test run",
		"test:rhea": "cd app/rhea-backend && npm run test",
		"test:calliope": "cd app/calliope-websockets && npm run test",
		"test:orpheus": "cd app/orpheus-mcp && npm run test",
		"test:e2e": "cd test/e2e && npm run test",
		"test:e2e:run": "cd test/e2e && npm run test:local",
		"build:library": "cd library/tiptap-schema && npm run build",
		"build:styx": "cd app/styx-frontend && npm run build",
		"build:rhea": "cd app/rhea-backend && npm run build",
		"build:calliope": "cd app/calliope-websockets && npm run build",
		"build:orpheus": "cd app/orpheus-mcp && npm run build",
		"lint:styx": "cd app/styx-frontend && npm run lint",
		"lint:rhea": "cd app/rhea-backend && npm run lint",
		"lint:calliope": "cd app/calliope-websockets && npm run lint",
		"lint:orpheus": "cd app/orpheus-mcp && npm run lint"
	},
	"dependencies": {
		"@typescript-eslint/eslint-plugin": "^8.51.0",
		"@typescript-eslint/parser": "^8.51.0",
		"cloc": "^2.8.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-astro": "^1.6.0",
		"eslint-plugin-node": "^11.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"eslint-plugin-unused-imports": "^4.1.4",
		"lint-staged": "^16.4.0",
		"nodemon": "^3.1.9",
		"prettier": "^3.4.2",
		"subpackage": "^1.1.0",
		"typescript": "^6.0.2"
	},
	"lint-staged": {
		"*.(ts|json)": "eslint --fix"
	},
	"engines": {
		"node": "24.x"
	},
	"author": "Tenebrie",
	"bugs": {
		"url": "https://github.com/tenebrie/timelines/issues"
	},
	"homepage": "https://github.com/tenebrie/timelines#readme",
	"devDependencies": {
		"astro-eslint-parser": "^1.2.2",
		"eslint-plugin-mui-path-imports": "^0.0.15",
		"eslint-plugin-no-relative-import-paths": "^1.6.1",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"prettier-plugin-astro": "^0.14.1",
		"husky": "^9.1.7",
		"typescript-eslint": "^8.51.0"
	}
}
