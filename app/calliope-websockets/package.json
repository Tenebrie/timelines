{
	"name": "calliope-websockets",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"description": "",
	"license": "GPL-3.0-or-later",
	"author": "Tenebrie",
	"scripts": {
		"tsc": "tsc --noEmit",
		"build": "tsc -p . && tsc-alias -p tsconfig.json",
		"openapi": "openapi-typescript http://localhost:3000/api-json -o ./src/api/rhea-api.ts",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"prod": "node dist/index.js",
		"prune-build-modules": "yarn install --production --ignore-scripts --prefer-offline",
		"start": "nodemon --watch src --ext ts,js,json --ignore 'src/**/*.spec.ts' --exec 'tsx src/index.ts'",
		"test": "vitest --run",
		"test:watch": "vitest"
	},
	"lint-staged": {
		"*.(ts)": "eslint --fix"
	},
	"dependencies": {
		"@koa/router": "^15.4.0",
		"@y/websocket-server": "0.1.1",
		"chalk": "^5.6.2",
		"cheerio": "^1.2.0",
		"dotenv": "^17.4.2",
		"http-status-codes": "^2.3.0",
		"jsonwebtoken": "^9.0.3",
		"koa": "^3.2.0",
		"koa-bodyparser": "^4.4.1",
		"koa-route": "^4.0.1",
		"koa-websocket": "^7.0.0",
		"lint-staged": "^15.2.11",
		"nodemon": "^3.1.14",
		"openapi-fetch": "^0.17.0",
		"pg": "^8.20.0",
		"redis": "^4.7.0",
		"ws": "^8.20.0",
		"yjs": "^13.6.30"
	},
	"devDependencies": {
		"@types/jsonwebtoken": "^9.0.10",
		"@types/koa": "^3.0.2",
		"@types/koa-bodyparser": "^4.3.13",
		"@types/koa-route": "^3.2.9",
		"@types/koa-websocket": "^5.0.11",
		"@types/koa__router": "^12.0.5",
		"@types/mock-knex": "^0.4.8",
		"@types/node": "^24.1.0",
		"@types/supertest": "^7.2.0",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.58.1",
		"@typescript-eslint/parser": "^8.58.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"jsdom": "^26.0.0",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.8.2",
		"source-map-support": "^0.5.20",
		"supertest": "^7.2.2",
		"ts-node": "^10.9.2",
		"ts-node-dev": "^2.0.0",
		"tsc-alias": "^1.8.16",
		"tsconfig-paths": "4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^3.0.9"
	}
}
