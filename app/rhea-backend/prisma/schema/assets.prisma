enum AssetType {
  Avatar
  ImageConversion
  ImageGeneration
  DataMigrationExport
  DataMigrationImport
  ImageEmbed
}

enum AssetStatus {
  Pending
  Finalized
  Failed
}

model Asset {
  id        String    @id @unique @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  bucketKey String

  size                  Int
  originalFileName      String
  originalFileExtension String
  contentType           AssetType
  status                AssetStatus @default(Pending)

  contentDescription String?
  imageWidth         Int?
  imageHeight        Int?

  references AssetReference[]
  avatarOf   User?            @relation("UserAvatar")
}

enum ReferenceHoldingEntity {
  Actor
  Event
  Article
  Tag
}

model AssetReference {
  id        String   @id @unique @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assetId    String
  holderId   String
  holderType ReferenceHoldingEntity

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  holderActorId   String?
  holderEventId   String?
  holderArticleId String?
  holderTagId     String?

  holderActor   Actor?       @relation(fields: [holderActorId], references: [id], onDelete: Cascade, name: "ActorAssetReference")
  holderEvent   WorldEvent?  @relation(fields: [holderEventId], references: [id], onDelete: Cascade, name: "EventAssetReference")
  holderArticle WikiArticle? @relation(fields: [holderArticleId], references: [id], onDelete: Cascade, name: "ArticleAssetReference")
  holderTag     Tag?         @relation(fields: [holderTagId], references: [id], onDelete: Cascade, name: "TagAssetReference")

  @@unique([assetId, holderId])
}
