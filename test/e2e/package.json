{
	"name": "e2e-test",
	"version": "0.0.0",
	"license": "GPL-3.0-or-later",
	"description": "",
	"scripts": {
		"lint": "eslint ./",
		"build": "docker compose build playwright",
		"test": "yarn build && yarn test:local",
		"test:report": "serve ./test-report/html --listen 3605",
		"test:local": ". ../../scripts/prepare-local-dev.sh && TARGET_ENV=local docker compose -f docker-compose.yml -f docker-compose.local.yml run --service-ports --rm playwright",
		"test:staging": ". ../../scripts/prepare-local-dev.sh && TARGET_ENV=staging docker compose run --rm playwright",
		"test:prod": ". ../../scripts/prepare-local-dev.sh && TARGET_ENV=prod docker compose run --rm playwright",
		"test:ui": "TARGET_ENV=local_ui playwright test --ui",
		"test:staging:ui": "TARGET_ENV=staging playwright test --ui"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"cloc": "^2.8.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-node": "^11.1.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"prettier": "^3.8.3",
		"serve": "^14.2.6",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": "24.x"
	},
	"subPackages": [],
	"author": "Tenebrie",
	"bugs": {
		"url": "https://github.com/tenebrie/timelines/issues"
	},
	"homepage": "https://github.com/tenebrie/timelines#readme"
}
